# ============================================================================
# NoteGod Landing — Environment Variables
# ============================================================================
# Copy this file to .env for development, and configure these same vars
# in Vercel's dashboard for production deployment.
#
# Note: Astro exposes any variable prefixed with PUBLIC_ to the client.
# ============================================================================

# --- Supabase ----------------------------------------------------------------
# Must point to the SAME Supabase project as the dashboard so auth sessions
# can be shared via the token handoff flow.
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Dashboard URL -----------------------------------------------------------
# Where to redirect users after successful auth.
# Dev: http://localhost:3000   Prod: https://app.notegod.io
PUBLIC_APP_URL=http://localhost:3000
