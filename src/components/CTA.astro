---
---

<section class="py-32 bg-noter-surface relative overflow-hidden fade-up">
  <!-- Background accent glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full opacity-[0.04]" style="background: radial-gradient(circle, #edff00 0%, transparent 70%);"></div>

  <div class="max-w-3xl mx-auto px-6 text-center relative z-10">
    <h2 class="uppercase tracking-tight mb-6" style="font-family: var(--font-family-display); font-size: clamp(3.5rem, 10vw, 7rem); line-height: 0.85;">
      Start organizing your ideas <span class="text-noter-accent">today</span>
    </h2>
    <p class="text-noter-text-muted text-lg mb-10 max-w-xl mx-auto">
      Join thousands of students, freelancers, and teams who trust NoteGod.
    </p>
    <a
      href="/register"
      class="inline-block px-10 py-4 text-lg font-semibold text-black rounded-xl hover:brightness-110 hover:-translate-y-0.5 transition-all"
      style="background: linear-gradient(135deg, #edff00, #b8d900);"
    >
      Get Started Free
    </a>
    <p class="text-noter-text-dim text-sm mt-4">No credit card required. Free forever plan available.</p>
  </div>
</section>
