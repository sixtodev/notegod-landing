---
const points = [
  "AES-256-GCM encryption for all note content",
  "Encryption keys never leave your account",
  "Zero-knowledge architecture: we can't read your notes",
  "HTTPS everywhere with TLS 1.3",
  "Supabase Row Level Security (RLS) on all data",
  "SOC 2 compliant infrastructure",
  "GDPR compliant",
];
---

<section id="security" class="py-24 fade-up">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Shield visual -->
    <div class="flex flex-col items-center justify-center">
      <div class="relative w-40 h-40 flex items-center justify-center">
        <!-- Pulse rings -->
        <div class="absolute inset-0 rounded-full border-2 border-noter-accent/20 animate-[pulse-ring_3s_ease-out_infinite]"></div>
        <div class="absolute inset-[-12px] rounded-full border border-noter-accent/10 animate-[pulse-ring_3s_ease-out_infinite_0.5s]"></div>
        <div class="absolute inset-[-24px] rounded-full border border-noter-accent/5 animate-[pulse-ring_3s_ease-out_infinite_1s]"></div>
        <!-- Shield -->
        <div class="w-28 h-28 rounded-2xl bg-noter-accent/10 flex items-center justify-center border border-noter-accent/20">
          <span class="text-5xl text-noter-accent">&#128737;</span>
        </div>
      </div>
      <p class="text-noter-accent text-sm font-semibold uppercase tracking-wider mt-6">Zero-knowledge architecture</p>
    </div>

    <!-- Text -->
    <div>
      <h2 class="uppercase tracking-tight mb-8" style="font-family: var(--font-family-display); font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 0.9;">
        Your privacy is<br/><span class="text-noter-accent">not optional</span>
      </h2>
      <ul class="flex flex-col gap-4">
        {points.map((point) => (
          <li class="flex items-start gap-3">
            <span class="text-noter-green mt-0.5 flex-shrink-0 font-bold">&#10003;</span>
            <span class="text-noter-text-muted text-sm leading-relaxed">{point}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(1.5); opacity: 0; }
  }
</style>
