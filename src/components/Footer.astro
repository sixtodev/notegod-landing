---
const productLinks = [
  { label: "Features", href: "/#features" },
  { label: "Pricing", href: "/#pricing" },
  { label: "Security", href: "/#security" },
  { label: "FAQ", href: "/#faq" },
];

const legalLinks = [
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
  { label: "GDPR", href: "/privacy#gdpr" },
];
---

<footer class="bg-noter-surface border-t border-noter-border">
  <div class="max-w-6xl mx-auto px-6 py-12 sm:py-14">
    <!-- Top: Brand spans wider on the left, link columns hug the right -->
    <div class="grid grid-cols-1 sm:grid-cols-12 gap-8">
      <!-- Brand -->
      <div class="sm:col-span-6 lg:col-span-7">
        <div class="flex items-center gap-2 mb-3">
          <img src="/notegod.png" alt="NoteGod" width="28" height="28" />
          <span class="text-noter-accent font-bold tracking-tight">NoteGod</span>
        </div>
        <p class="text-noter-text-dim text-xs leading-relaxed mb-3 max-w-sm">Secure notes for everyone. Encrypt, organize, and share your ideas.</p>
        <a href="mailto:support@notegod.io" class="text-noter-text-dim text-xs hover:text-noter-accent transition-colors">support@notegod.io</a>
      </div>

      <!-- Product -->
      <div class="sm:col-span-3 lg:col-span-2">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-noter-text-muted mb-4">Product</h4>
        <ul class="flex flex-col gap-2">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-noter-text-dim hover:text-noter-text transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="sm:col-span-3 lg:col-span-3">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-noter-text-muted mb-4">Legal</h4>
        <ul class="flex flex-col gap-2">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-noter-text-dim hover:text-noter-text transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom: just copyright centered -->
    <div class="mt-10 pt-6 border-t border-noter-border text-center">
      <p class="text-noter-text-dim text-xs">© 2026 NoteGod</p>
    </div>
  </div>
</footer>
