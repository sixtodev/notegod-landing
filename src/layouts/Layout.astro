---
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title = "NoteGod - Secure Note-Taking for Students, Freelancers & Teams",
  description = "The most affordable note-taking app with AES-256 encryption, offline mode, Google Drive integration, Web Clipper, and team collaboration. Free forever plan available.",
  canonical = "https://notegod.io",
  noindex = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const fullUrl = `https://notegod.io${currentPath === '/' ? '' : currentPath}`;
const authPages = ['/login', '/register', '/forgot-password', '/reset-password'];
const shouldNoindex = noindex || authPages.some(p => currentPath.startsWith(p));

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "NoteGod",
  "url": "https://notegod.io",
  "logo": "https://notegod.io/notegod.png",
  "description": "Secure note-taking app for students, freelancers, and teams.",
  "sameAs": []
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "NoteGod",
  "applicationCategory": "ProductivityApplication",
  "operatingSystem": "Web, PWA",
  "url": "https://notegod.io",
  "description": description,
  "offers": [
    {
      "@type": "Offer",
      "name": "Free",
      "price": "0",
      "priceCurrency": "USD"
    },
    {
      "@type": "Offer",
      "name": "Pro",
      "price": "2.99",
      "priceCurrency": "USD",
      "billingIncrement": "P1M"
    },
    {
      "@type": "Offer",
      "name": "Team",
      "price": "3.99",
      "priceCurrency": "USD",
      "billingIncrement": "P1M"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is there a free plan?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, NoteGod Free includes unlimited notes, rich text editor, encryption, offline mode, and basic tags. No credit card required." }},
    { "@type": "Question", "name": "Is my data encrypted?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, all note content is encrypted with AES-256-GCM before storage. We use zero-knowledge architecture, meaning we cannot read your notes." }},
    { "@type": "Question", "name": "Can I use NoteGod offline?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, NoteGod is a PWA that works fully offline. Changes sync automatically when you reconnect." }},
    { "@type": "Question", "name": "How does the free trial work?", "acceptedAnswer": { "@type": "Answer", "text": "Every paid plan includes a 7-day free trial with no credit card required. You get full access to all features. When it ends, you go back to the Free plan. No charges without your consent." }},
    { "@type": "Question", "name": "What's the student discount?", "acceptedAnswer": { "@type": "Answer", "text": "Students with a valid .edu email get NoteGod Pro for $1.49/mo instead of $2.99/mo." }},
    { "@type": "Question", "name": "How does team collaboration work?", "acceptedAnswer": { "@type": "Answer", "text": "Create a project, invite members as editors or viewers. Editors can create and modify notes, viewers have read-only access. Add comments and track changes with the activity feed." }},
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {shouldNoindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#1a1a1c" />
    <meta name="keywords" content="note taking app, secure notes, encrypted notes, notes for students, team notes, offline notes, WYSIWYG editor, cheap note app, Notion alternative, Obsidian alternative, Evernote alternative, Joplin alternative, notas seguras, aplicacion de notas" />
    <meta name="author" content="NoteGod" />
    <link rel="canonical" href={fullUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:site_name" content="NoteGod" />
    <meta property="og:image" content="https://notegod.io/notegod.png" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://notegod.io/notegod.png" />

    <!-- hreflang: solo English por ahora, x-default apunta a la misma -->
    <link rel="alternate" hreflang="en" href={fullUrl} />
    <link rel="alternate" hreflang="x-default" href={fullUrl} />

    <meta name="geo.region" content="US" />
    <meta name="geo.region" content="MX" />
    <meta name="geo.region" content="CA" />

    <link rel="icon" type="image/png" href="/notegod.png" />
    <title>{title}</title>

    <!-- Preload fonts -->
    <link rel="preload" href="/fonts/Morganite-Bold.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Morganite-Black.ttf" as="font" type="font/ttf" crossorigin />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    {currentPath === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </head>
  <body>
    <slot />

    <script>
      // Intersection Observer for fade-in animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.fade-up, .stagger-children').forEach((el) => {
        observer.observe(el);
      });
    </script>
    <CookieBanner />
  </body>
</html>
